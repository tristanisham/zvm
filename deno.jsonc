{
  "tasks": {
    "build": "deno run -A build.ts",
    "build:win-installer": "cmake -B cmake-build -DCMAKE_BUILD_TYPE=Release && cmake --build cmake-build --config Release",
    "clean": "rm -r build"
  },
  "imports": {
    "@std/cli": "jsr:@std/cli@^1.0.28",
    "@std/path": "jsr:@std/path@^0.219.1",
    "@zip-js/zip-js": "jsr:@zip-js/zip-js@^2.8.24"
  }
}
